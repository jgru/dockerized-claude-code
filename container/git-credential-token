#!/bin/bash
[ "$1" != "get" ] && exit 0

declare -A REQ
while IFS='=' read -r key value; do
    [ -z "$key" ] && break
    REQ["$key"]="$value"
done

case "${REQ[host]}" in
    github.com)                TOKEN="${GITHUB_TOKEN:-}" ;;
    gitlab.com)                TOKEN="${GITLAB_TOKEN:-}" ;;
    # Add custom domain here 
    *)                         TOKEN="${GIT_TOKEN:-}" ;;
esac

[ -z "$TOKEN" ] && exit 1

echo "protocol=${REQ[protocol]:-https}"
echo "host=${REQ[host]}"
echo "username=x-token"
echo "password=${TOKEN}"
